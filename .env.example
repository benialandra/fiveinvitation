# API Keys Konfigurasi
# Dapatkan di dashboard Supabase
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_ANON_KEY="your-supabase-anon-key"

# Dapatkan di dashboard Midtrans (Environment: Sandbox untuk testing, Production untuk rilis)
VITE_MIDTRANS_CLIENT_KEY="your-midtrans-client-key"
MIDTRANS_SERVER_KEY="your-midtrans-server-key"
MIDTRANS_IS_PRODUCTION="false"

# Base URL Aplikasi
VITE_APP_URL="http://localhost:3000"
APP_URL="http://localhost:3000"

# Admin Authentication (SERVER-SIDE ONLY — jangan pakai prefix VITE_!)
ADMIN_PASSWORD="ganti-dengan-password-kuat-anda"
ADMIN_TOKEN_SECRET="ganti-dengan-random-string-32-karakter"

# SMTP Configurations for Automated Email Reminders
# Gunakan Gmail App Password (bukan password utama Gmail!)
# Cara membuat: Google Account > Security > 2FA > App Passwords
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="your_email@gmail.com"
SMTP_PASS="your_app_password"

